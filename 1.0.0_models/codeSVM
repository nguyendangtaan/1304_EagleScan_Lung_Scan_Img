"import numpy as np\n","from skimage.feature import hog, graycomatrix, graycoprops\n","from sklearn.svm import SVC\n","from sklearn.metrics import accuracy_score, classification_report, confusion_matrix\n","from sklearn.decomposition import PCA\n","from sklearn.preprocessing import StandardScaler\n","import os\n","from pathlib import Path\n","import random\n","import albumentations as A"],"metadata":{"id":"asb_F3oAcGnU","executionInfo":{"status":"ok","timestamp":1747627273515,"user_tz":-420,"elapsed":8,"user":{"displayName":"Tân Nguyễn Đăng","userId":"10700933104330438522"}}},"execution_count":13,"outputs":[]},{"cell_type":"code","execution_count":14,"metadata":{"id":"feqp5J2xa8OI","executionInfo":{"status":"ok","timestamp":1747627276081,"user_tz":-420,"elapsed":27,"user":{"displayName":"Tân Nguyễn Đăng","userId":"10700933104330438522"}}},"outputs":[],"source":["\n","# Định nghĩa đường dẫn đến thư mục dữ liệu\n","data_dir = '/content/drive/MyDrive/KLTN/Storage Dataset/Chest CT-Scan images Dataset'\n","categories_train_valid = [\n","    'adenocarcinoma_left.lower.lobe_T2_N0_M0_Ib',\n","    'large.cell.carcinoma_left.hilum_T2_N2_M0_IIIa',\n","    'squamous.cell.carcinoma_left.hilum_T1_N2_M0_IIIa',\n","    'normal'\n","]\n","categories_test = [\n","    'adenocarcinoma',\n","    'large.cell.carcinoma',\n","    'squamous.cell.carcinoma',\n","    'normal'\n","]\n","\n","# Danh sách tên hiển thị (cho báo cáo phân loại)\n","category_names = [\n","    'Adenocarcinoma',\n","    'Large Cell Carcinoma',\n","    'Squamous Cell Carcinoma',\n","    'Normal'\n","]\n","image_size = (128, 128)  # Kích thước ảnh sau khi resize"]},{"cell_type":"code","source":["# Hàm tiền xử lý cho segmentation\n","def preprocess_for_segmentation(image):\n","    # Bước 1: Chuyển ảnh sang thang độ xám\n","    gray = cv2.cvtColor(image, cv2.COLOR_BGR2GRAY)\n","\n","    # Bước 2: Làm mịn ảnh (loại bỏ nhiễu) bằng Gaussian Blur\n","    gray = cv2.GaussianBlur(gray, (5, 5), 0)\n","\n","    # Bước 3: Tăng cường độ tương phản bằng CLAHE\n","    clahe = cv2.createCLAHE(clipLimit=2.0, tileGridSize=(8, 8))\n","    gray = clahe.apply(gray)\n","\n","    # Bước 4: Chuẩn hóa giá trị pixel về [0, 1]\n","    gray = gray / 255.0\n","\n","    return gray\n","\n","# Hàm thực hiện segmentation bằng ngưỡng hóa\n","def segment_image(image):\n","    gray = preprocess_for_segmentation(image)\n","    _, binary = cv2.threshold((gray * 255).astype(np.uint8), 0, 255, cv2.THRESH_BINARY + cv2.THRESH_OTSU)\n","    masked_image = cv2.bitwise_and(image, image, mask=binary)\n","    return masked_image, binary"],"metadata":{"id":"u5YMoCUhr8ZZ","executionInfo":{"status":"ok","timestamp":1747627942078,"user_tz":-420,"elapsed":45,"user":{"displayName":"Tân Nguyễn Đăng","userId":"10700933104330438522"}}},"execution_count":24,"outputs":[]},{"cell_type":"code","source":["\n","\n","# Hàm tiền xử lý ảnh trước khi trích xuất GLCM\n","def preprocess_image(image, is_train=False):\n","    # Segmentation trước khi trích xuất đặc trưng\n","    masked_image, _ = segment_image(image)\n","\n","    # Bước 1: Chuyển ảnh sang thang độ xám\n","    gray = cv2.cvtColor(masked_image, cv2.COLOR_BGR2GRAY)\n","\n","    # Bước 2: Chuẩn hóa kích thước ảnh\n","    gray = cv2.resize(gray, image_size)\n","\n","    # Bước 3: Làm mịn ảnh (loại bỏ nhiễu) bằng Gaussian Blur\n","    gray = cv2.GaussianBlur(gray, (5, 5), 0)\n","\n","    # Bước 4: Tăng cường độ tương phản bằng CLAHE\n","    clahe = cv2.createCLAHE(clipLimit=2.0, tileGridSize=(8, 8))\n","    gray = clahe.apply(gray)\n","\n","    # Bước 5: Chuẩn hóa giá trị pixel về [0, 1]\n","    gray = gray / 255.0\n","\n","    # Bước 6: Tăng cường dữ liệu (chỉ áp dụng cho tập train)\n","    if is_train:\n","        transform = A.Compose([\n","            A.Rotate(limit=30, p=0.7),  # Tăng góc xoay để tạo thêm dữ liệu\n","            A.HorizontalFlip(p=0.5),\n","            A.RandomBrightnessContrast(brightness_limit=0.3, contrast_limit=0.3, p=0.7),\n","            A.RandomScale(scale_limit=(-0.1, 0.1), p=0.5)  # Hiệu ứng zoom\n","        ])\n","        augmented = transform(image=(gray * 255).astype(np.uint8))\n","        gray = augmented['image'] / 255.0\n","\n","    # Chuyển về kiểu uint8 (0-255) cho GLCM\n","    gray = (gray * 255).astype(np.uint8)\n","\n","    return gray\n","\n","# Hàm trích xuất đặc trưng GLCM\n","def extract_glcm_features(image, is_train=False):\n","    gray = preprocess_image(image, is_train)\n","\n","    # Tính GLCM\n","    distances = [1, 3, 5]  # Thêm nhiều khoảng cách để tăng thông tin texture\n","    angles = [0, np.pi/4, np.pi/2, 3*np.pi/4]\n","    glcm = graycomatrix(gray, distances=distances, angles=angles, levels=256, symmetric=True, normed=True)\n","\n","    # Trích xuất đặc trưng GLCM\n","    features = []\n","    properties = ['contrast', 'dissimilarity', 'homogeneity', 'energy', 'correlation']\n","    for prop in properties:\n","        prop_values = graycoprops(glcm, prop).flatten()\n","        features.extend(prop_values)\n","\n","    return np.array(features)\n","\n","\n",""],"metadata":{"id":"nWZCIQ5FuKrG","executionInfo":{"status":"ok","timestamp":1747627948954,"user_tz":-420,"elapsed":34,"user":{"displayName":"Tân Nguyễn Đăng","userId":"10700933104330438522"}}},"execution_count":25,"outputs":[]},{"cell_type":"code","source":["# Hàm tải dữ liệu\n","def load_data(data_type='train'):\n","    images = []\n","    labels = []\n","    folder_path = os.path.join(data_dir, data_type)\n","\n","    if not os.path.exists(folder_path):\n","        print(f\"Thư mục không tồn tại: {folder_path}\")\n","        return np.array([]), np.array([])\n","\n","    # Chọn danh sách categories phù hợp\n","    categories = categories_train_valid if data_type in ['train', 'valid'] else categories_test\n","    is_train = (data_type == 'train')\n","\n","    for category in categories:\n","        category_path = os.path.join(folder_path, category)\n","        if not os.path.exists(category_path):\n","            print(f\"Thư mục không tồn tại: {category_path}\")\n","            continue\n","        # Ánh xạ nhãn\n","        if data_type in ['train', 'valid']:\n","            if 'adenocarcinoma' in category:\n","                label = categories_test.index('adenocarcinoma')\n","            elif 'large.cell.carcinoma' in category:\n","                label = categories_test.index('large.cell.carcinoma')\n","            elif 'squamous.cell.carcinoma' in category:\n","                label = categories_test.index('squamous.cell.carcinoma')\n","            else:\n","                label = categories_test.index('normal')\n","        else:\n","            label = categories_test.index(category)\n","\n","        for img_name in os.listdir(category_path):\n","            img_path = os.path.join(category_path, img_name)\n","            img = cv2.imread(img_path)\n","            if img is not None:\n","                features = extract_glcm_features(img, is_train)\n","                images.append(features)\n","                labels.append(label)\n","            else:\n","                print(f\"Không đọc được ảnh: {img_path}\")\n","\n","    return np.array(images), np.array(labels)\n","\n","# Tải dữ liệu\n","X_train, y_train = load_data('train')\n","X_valid, y_valid = load_data('valid')\n","X_test, y_test = load_data('test')\n","\n","# Kiểm tra kích thước và nhãn\n","print(f\"Kích thước tập train: {X_train.shape}, {y_train.shape}\")\n","print(f\"Nhãn tập train: {np.unique(y_train)}\")\n","print(f\"Kích thước tập valid: {X_valid.shape}, {y_valid.shape}\")\n","print(f\"Nhãn tập valid: {np.unique(y_valid)}\")\n","print(f\"Kích thước tập test: {X_test.shape}, {y_test.shape}\")\n","print(f\"Nhãn tập test: {np.unique(y_test)}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"d-K-9BK-vmUO","executionInfo":{"status":"ok","timestamp":1747628276554,"user_tz":-420,"elapsed":312854,"user":{"displayName":"Tân Nguyễn Đăng","userId":"10700933104330438522"}},"outputId":"99d736b5-95fb-4e21-f187-7885134a5e01"},"execution_count":26,"outputs":[{"output_type":"stream","name":"stdout","text":["Kích thước tập train: (613, 60), (613,)\n","Nhãn tập train: [0 1 2 3]\n","Kích thước tập valid: (72, 60), (72,)\n","Nhãn tập valid: [0 1 2 3]\n","Kích thước tập test: (315, 60), (315,)\n","Nhãn tập test: [0 1 2 3]\n"]}]},{"cell_type":"code","source":["# Chuẩn hóa dữ liệu trước khi áp dụng PCA\n","scaler = StandardScaler()\n","X_train_scaled = scaler.fit_transform(X_train)\n","X_valid_scaled = scaler.transform(X_valid)\n","X_test_scaled = scaler.transform(X_test)\n","\n","# Áp dụng PCA\n","n_components = 30  # Giảm xuống 30 chiều, vì GLCM chỉ có 60 chiều\n","pca = PCA(n_components=n_components, random_state=42)\n","X_train_pca = pca.fit_transform(X_train_scaled)\n","X_valid_pca = pca.transform(X_valid_scaled)\n","X_test_pca = pca.transform(X_test_scaled)\n","\n","# Kiểm tra tỷ lệ phương sai giữ lại\n","explained_variance_ratio = np.sum(pca.explained_variance_ratio_)\n","print(f\"Tỷ lệ phương sai giữ lại với {n_components} thành phần: {explained_variance_ratio:.4f}\")"],"metadata":{"id":"5mFvKWUww4rI","executionInfo":{"status":"ok","timestamp":1747628300127,"user_tz":-420,"elapsed":75,"user":{"displayName":"Tân Nguyễn Đăng","userId":"10700933104330438522"}},"outputId":"03a111ee-e2b4-4564-ef49-29c8f8d058e3","colab":{"base_uri":"https://localhost:8080/"}},"execution_count":27,"outputs":[{"output_type":"stream","name":"stdout","text":["Tỷ lệ phương sai giữ lại với 30 thành phần: 0.9999\n"]}]},{"cell_type":"code","source":["# Huấn luyện SVM với các cải thiện\n","svm_model = SVC(kernel='rbf', C=0.1, class_weight='balanced', random_state=42)  # Giảm C để tăng regularization\n","svm_model.fit(X_train_pca, y_train)\n","\n","# Dự đoán và đánh giá\n","y_valid_pred = svm_model.predict(X_valid_pca)\n","y_test_pred = svm_model.predict(X_test_pca)\n","\n","print(\"Độ chính xác trên tập valid:\", accuracy_score(y_valid, y_valid_pred))\n","print(\"Báo cáo phân loại trên tập valid:\\n\", classification_report(y_valid, y_valid_pred, target_names=category_names))\n","print(\"Ma trận nhầm lẫn trên tập valid:\\n\", confusion_matrix(y_valid, y_valid_pred))\n","\n","print(\"\\nĐộ chính xác trên tập test:\", accuracy_score(y_test, y_test_pred))\n","print(\"Báo cáo phân loại trên tập test:\\n\", classification_report(y_test, y_test_pred, target_names=category_names))\n","print(\"Ma trận nhầm lẫn trên tập test:\\n\", confusion_matrix(y_test, y_test_pred))"],"metadata":{"id":"0mDUkI8Xw7mm","executionInfo":{"status":"ok","timestamp":1747628314657,"user_tz":-420,"elapsed":96,"user":{"displayName":"Tân Nguyễn Đăng","userId":"10700933104330438522"}},"outputId":"54d5ccc2-05b1-4584-a057-ac47beaceaff","colab":{"base_uri":"https://localhost:8080/"}},"execution_count":28,"outputs":[{"output_type":"stream","name":"stdout","text":["Độ chính xác trên tập valid: 0.5138888888888888\n","Báo cáo phân loại trên tập valid:\n","                          precision    recall  f1-score   support\n","\n","         Adenocarcinoma       0.45      0.87      0.60        23\n","   Large Cell Carcinoma       0.50      0.05      0.09        21\n","Squamous Cell Carcinoma       0.33      0.20      0.25        15\n","                 Normal       0.76      1.00      0.87        13\n","\n","               accuracy                           0.51        72\n","              macro avg       0.51      0.53      0.45        72\n","           weighted avg       0.50      0.51      0.42        72\n","\n","Ma trận nhầm lẫn trên tập valid:\n"," [[20  0  3  0]\n"," [14  1  3  3]\n"," [10  1  3  1]\n"," [ 0  0  0 13]]\n","\n","Độ chính xác trên tập test: 0.2634920634920635\n","Báo cáo phân loại trên tập test:\n","                          precision    recall  f1-score   support\n","\n","         Adenocarcinoma       0.23      0.17      0.19       120\n","   Large Cell Carcinoma       0.00      0.00      0.00        51\n","Squamous Cell Carcinoma       0.35      0.10      0.16        90\n","              